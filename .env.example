# Copy to .env and fill in. .env is gitignored — never commit real keys.
#
# Both values come from your Supabase project:
#   Dashboard -> Project Settings -> API Keys

# e.g. https://abcdefghijklm.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# The SECRET key (`sb_secret_...`; on older projects, the `service_role` JWT).
#
# It bypasses Row Level Security — that is exactly why the collector can write
# and the public cannot. Treat it like a password:
#   - it belongs ONLY in this .env, on the collector machine
#   - it must NEVER appear in docs/, in the frontend, or in a commit
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Optional. The publishable/anon key is NOT needed by this project: the dashboard
# reads a public Storage bucket, so the page embeds no key at all.
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# GIT_TOKEN is gone. The collector no longer pushes to git — that was the
# ~720-commits/day pattern that risked a ToS strike. GitHub Pages now only
# serves the static frontend, deployed by Actions on real code commits.
